# =============================================================================
# OpenClaw Starter — 設定ファイル
# =============================================================================
# このファイルを `.env` という名前でコピーして、必要な値だけ埋めてください。
#
# Windows: メモ帳でもVSCodeでもOK
# Mac:     テキストエディット or VSCode
#
# ⚠️ ".env" ファイルはGitに上げないでください（.gitignoreで除外済み）
# =============================================================================


# -----------------------------------------------------------------------------
# 🤖 LLM API（どれか1個あればOK、後でいくつでも切り替えられる）
# -----------------------------------------------------------------------------

# 🥇 おすすめ: Google Gemini Flash（無料1500回/日、Googleアカウントだけで取れる）
# 取得方法: https://aistudio.google.com/apikey にアクセス → "Create API key" → コピペ
# ⚠️ 注意: 無料枠は会話内容がGoogleの学習に使われます（気になる場合は Anthropic/OpenAI へ）
GEMINI_API_KEY=

# Anthropic Claude（有料、月額3000円〜）
# 取得方法: https://console.anthropic.com/ → API Keys → Create Key
# ANTHROPIC_API_KEY=

# OpenAI（有料、従量課金）
# 取得方法: https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# OpenRouter（1つのキーで100以上のモデルにアクセスできる、無料モデルもあり）
# 取得方法: https://openrouter.ai/keys
# OPENROUTER_API_KEY=


# -----------------------------------------------------------------------------
# 💬 Discord（DiscordからAIバディに話しかけたい場合に必要）
# -----------------------------------------------------------------------------
# 取得方法: README.md の「Discord Bot の作り方」を参照
DISCORD_BOT_TOKEN=


# -----------------------------------------------------------------------------
# 🔒 Gateway認証トークン（必ず設定してください）
# -----------------------------------------------------------------------------
# Dashboardにアクセスする時のパスワード代わりです。
# ターミナルで以下を実行 → 出てきた長い文字列をコピーして "=" の右側に貼ってください:
#
#   Mac/Linux:        openssl rand -hex 32
#   Windows PowerShell: -join ((1..32) | ForEach-Object { '{0:x2}' -f (Get-Random -Maximum 256) })
#
# ※ 空のままにすると初回起動時に自動生成されますが、後でDashboard用に取り出す
#   手間が発生するので、最初に生成しておく方が楽です。
OPENCLAW_GATEWAY_TOKEN=


# -----------------------------------------------------------------------------
# 🔌 ポート設定（18789 が他で使われてる場合は変えてください）
# -----------------------------------------------------------------------------
# 例: OPENCLAW_GATEWAY_PORT=28789
# OPENCLAW_GATEWAY_PORT=18789
